---
layout: default
---
<div class="post about-jp">
  <header class="post-header">
    {% if site.icon %}
      {% assign title_icon_path = site.icon | prepend: 'assets/img/' | relative_url %}
      {% assign academic_icon_path = 'assets/img/logo/icon_academic.jpg' | relative_url %}
      {% assign meow_icon_path = 'assets/img/logo/icon_meow.png' | relative_url %}
    {% endif %}
    <div class="about-identity">
      {% if site.icon %}
        <button type="button" class="post-title-avatar-button" aria-label="Show greeting">
          <img
            class="post-title-avatar"
            src="{{ title_icon_path }}"
            data-default-icon="{{ title_icon_path }}"
            data-academic-icon="{{ academic_icon_path }}"
            data-meow-icon="{{ meow_icon_path }}"
            alt=""
            aria-hidden="true"
            draggable="false"
          >
        </button>
      {% endif %}
      <p class="about-hello">
        <span class="about-hello-rotator" aria-live="polite">Hi there / 你好 / こんにちは / 안녕 / Ciallo ～(∠・ω&lt; )⌒★</span>
      </p>
    </div>
    {% if page.subtitle %}
      <p class="desc">{{ page.subtitle }}</p>
    {% endif %}
  </header>

  <article>
    {% if page.profile and page.profile.hide != true %}
      <div class="profile float-{% if page.profile.align == 'left' %}left{% else %}right{% endif %}">
        {% if page.profile.image %}
          {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
          {% if page.profile.image_circular %}
            {% assign profile_image_class = 'img-fluid z-depth-1 rounded-circle' %}
          {% else %}
            {% assign profile_image_class = 'img-fluid z-depth-1
      rounded' %}
          {% endif %}
          {% capture sizes %}(min-width: {{site.max_width}}) {{ site.max_width | minus: 30 | times: 0.3}}px, (min-width: 576px)
      30vw, 95vw"{% endcapture %}
          {%
            include figure.liquid loading="eager" fetchpriority="high" path=profile_image_path class=profile_image_class sizes=sizes alt=page.profile.image
            cache_bust=true
          %}
        {% endif %}
        {% if page.profile.more_info %}
          <div class="more-info">{{ page.profile.more_info }}</div>
        {% endif %}
      </div>
    {% endif %}

    {{ content }}

    <div style="clear: both;"></div>
  </article>
</div>
<script>
  (function () {
    var rotator = document.querySelector('.about-hello-rotator');
    var identity = document.querySelector('.about-identity');
    var avatar = document.querySelector('.post-title-avatar-button');
    var avatarImage = document.querySelector('.post-title-avatar');
    var bubble = document.querySelector('.about-hello');
    var promptBox = document.querySelector('.about-prompt');
    var aboutRoot = document.querySelector('.about-jp');
    var modelPicker = document.querySelector('.about-model-select');
    var contactAction = document.querySelector('[data-about-contact-action]');
    var contactIcon = contactAction ? contactAction.querySelector('i') : null;
    var scholarAction = document.querySelector('[data-about-scholar-action]');
    var scholarIcon = scholarAction ? scholarAction.querySelector('i') : null;
    var xAction = document.querySelector('[data-about-x-action]');
    var githubAction = document.querySelector('[data-about-github-action]');
    var githubIcon = githubAction ? githubAction.querySelector('i') : null;
    var panelTriggers = Array.prototype.slice.call(document.querySelectorAll('[data-about-panel-trigger]'));
    var inlinePanels = Array.prototype.slice.call(document.querySelectorAll('[data-about-panel]'));
    var collapseInlinePanels = null;

    if (!rotator || !identity || !avatar || !bubble || !promptBox) return;

    var speechModes = {
      Academic: {
        greetings: [
          {% assign recent_news = site.news | sort: 'date' | reverse %}
          {% for item in recent_news limit: 10 %}
            {% capture news_message -%}<span class="about-news-date">{{ item.date | date: '%m/%d/%y' }}</span> {{ item.content | markdownify | remove: '<p>' | remove: '</p>' | strip }}{%- endcapture %}
            {{ news_message | strip | jsonify }}{% unless forloop.last %},{% endunless %}
          {% endfor %}
        ],
        interactions: [
          {% for item in recent_news limit: 10 %}
            {% capture news_message -%}<span class="about-news-date">{{ item.date | date: '%m/%d/%y' }}</span> {{ item.content | markdownify | remove: '<p>' | remove: '</p>' | strip }}{%- endcapture %}
            {{ news_message | strip | jsonify }}{% unless forloop.last %},{% endunless %}
          {% endfor %}
        ],
      },
      Creative: {
        greetings: [
          '🤗 Hi there/你好/こんにちは/안녕/Ciallo ～(∠・ω< )⌒★',
          '🍭 This is Yolo Y. Tang (芸珑 in Mandarin or <ruby>夜<rt>よる</rt></ruby> in Japanese).',
          "🏠 Welcome to Yolo's personal website and have fun exploring!",
        ],
        interactions: [
          '🐾 Thanks for stopping by.',
          '🐈 Always happy to have curious visitors.',
          '✨ Feel free to explore the research and projects.',
          '📚 New ideas are usually hiding one click away.',
          '🩵 Hope you enjoy the visit.',
          '🎤 Yolo is really into J-pop, <a href="{{ \'/gallery/\' | relative_url }}">illustration</a>, and cosplay — maybe she’s just cosplaying as a researcher :)',
          "🪪 Please don't deadname or misgender Yolo. She prefers Yolo (in English) or 芸珑 (in Mandarin).",
          '🌙 Yolo also prefers <ruby>夜<rt>よる</rt></ruby> ("night" in Japanese), since Sonta pronounces Yolo like /ˈjoʊ lu/, close to よる.',
        ],
      },
      Meow: {
        greetings: [
          '🐾 Meow there / 你好 / こんにちは / 안녕 / Ciallo ～(∠・ω< )⌒★',
          '🐱 Yolo is currently accepting papers, ideas, treats, and gentle head pats.',
          '🐈 Paw around the site. If anything breaks, the cat was not here.',
        ],
        interactions: [
          '🐾 Mrrp. Yolo likes head pats and cozy snuggles.',
          '🐱 You clicked the cat. The cat approves this research direction.',
          '🍣 Purr review complete: promising, but needs more snacks.',
          '🐈 Tiny paw detected. Opening curiosity mode.',
          '😼 Meow mode is scientifically unserious. Please cite the cat responsibly.',
        ],
      },
    };
    // NEW O2: 按访问时段追加一句打头的问候（深夜 / 清晨 / 傍晚；白天保持原样）
    (function () {
      var hour = new Date().getHours();
      var timeGreetings = null;
      if (hour >= 23 || hour < 5) {
        timeGreetings = {
          Creative: '🌙 Welcome, fellow night owl.',
          Meow: '🐾 Meow?! It is nap time... but head pats are still accepted.',
        };
      } else if (hour < 11) {
        timeGreetings = {
          Creative: '🌅 Good morning! A brand-new day for brand-new ideas.',
          Meow: '🐱 Mrrp... early meow. Breakfast first, research second.',
        };
      } else if (hour >= 18) {
        timeGreetings = {
          Creative: '🌆 Good evening! The site glows a little softer at night.',
          Meow: '😼 Evening patrol complete. The couch is secured.',
        };
      }
      if (!timeGreetings) return;
      Object.keys(timeGreetings).forEach(function (mode) {
        if (speechModes[mode]) speechModes[mode].greetings.unshift(timeGreetings[mode]);
      });
    })();

    var currentSpeechMode = 'Academic';
    var newsArchiveUrl = "{{ '/news/' | relative_url }}";
    var names = speechModes[currentSpeechMode].greetings;
    var interactionMessages = speechModes[currentSpeechMode].interactions;
    var index = 0;
    var interactionIndex = 0;
    var clickTimer = null;
    var speechTimer = null;
    var autoCycleStepTimer = null;
    var speechRequestId = 0;
    var clickPopActive = false;
    var autoCycleActive = false;
    var bubbleHoverActive = false;
    var autoCycleIndex = 0;
    var pointerOffset = 1;
    var mascotRevealFallbackMs = 360;
    var typingSpeedMs = 5;
    var autoCycleIntervalMs = 15000;
    var autoCycleMeowIntervalMs = 7000;
    var autoCycleInitialDelayMs = 10000;
    var autoSpeechDurationMs = 5000;
    var autoCycleTimerId = null;
    var panelRestoreTimer = null;
    var panelHideTimer = null;

    function isMascotSpeechPaused() {
      if (!aboutRoot) return false;
      return (
        aboutRoot.classList.contains('is-inline-panel-open') ||
        aboutRoot.classList.contains('is-panel-hiding-mascot') ||
        aboutRoot.classList.contains('is-panel-restoring') ||
        aboutRoot.classList.contains('is-mascot-reappearing')
      );
    }

    function currentAutoCycleIntervalMs() {
      return currentSpeechMode === 'Meow' ? autoCycleMeowIntervalMs : autoCycleIntervalMs;
    }

    function restartAutoCycleInterval() {
      if (autoCycleTimerId === null) return;
      window.clearInterval(autoCycleTimerId);
      autoCycleTimerId = window.setInterval(startAutoSpeechCycle, currentAutoCycleIntervalMs());
    }

    function setSpeechMode(mode) {
      if (!speechModes[mode]) return;
      dismissSpeechBubble();
      if (mode === 'Meow' && typeof collapseInlinePanels === 'function') {
        collapseInlinePanels();
      }
      currentSpeechMode = mode;
      names = speechModes[currentSpeechMode].greetings;
      interactionMessages = speechModes[currentSpeechMode].interactions;
      index = 0;
      interactionIndex = 0;
      autoCycleIndex = 0;
      if (avatarImage) {
        if (mode === 'Academic') {
          avatarImage.src = avatarImage.dataset.academicIcon;
        } else if (mode === 'Meow') {
          avatarImage.src = avatarImage.dataset.meowIcon;
        } else {
          avatarImage.src = avatarImage.dataset.defaultIcon;
        }
      }
      if (contactAction && contactIcon) {
        var useTelegram = mode === 'Meow' && contactAction.dataset.telegramHref;
        var useDiscord = mode === 'Creative' && contactAction.dataset.discordHref;
        var href = useTelegram
          ? contactAction.dataset.telegramHref
          : useDiscord
            ? contactAction.dataset.discordHref
            : contactAction.dataset.emailHref;
        var label = useTelegram
          ? contactAction.dataset.telegramLabel
          : useDiscord
            ? contactAction.dataset.discordLabel
            : contactAction.dataset.emailLabel;
        var icon = useTelegram
          ? contactAction.dataset.telegramIcon
          : useDiscord
            ? contactAction.dataset.discordIcon
            : contactAction.dataset.emailIcon;
        contactAction.href = href;
        contactAction.title = label;
        contactAction.dataset.contactMode = useDiscord ? 'discord' : useTelegram ? 'telegram' : 'email';
        contactAction.setAttribute('aria-label', label);
        contactIcon.className = icon;
        if (useDiscord || useTelegram) {
          contactAction.target = '_blank';
          contactAction.rel = 'noopener noreferrer';
        } else {
          contactAction.removeAttribute('target');
          contactAction.removeAttribute('rel');
        }
      }
      if (scholarAction && scholarIcon) {
        var useInstagram = mode === 'Creative' || mode === 'Meow';
        var scholarHref = useInstagram ? scholarAction.dataset.instagramHref : scholarAction.dataset.scholarHref;
        var scholarLabel = useInstagram ? scholarAction.dataset.instagramLabel : scholarAction.dataset.scholarLabel;
        var scholarIconClass = useInstagram ? scholarAction.dataset.instagramIcon : scholarAction.dataset.scholarIcon;
        scholarAction.href = scholarHref;
        scholarAction.title = scholarLabel;
        scholarAction.setAttribute('aria-label', scholarLabel);
        scholarIcon.className = scholarIconClass;
      }
      if (xAction) {
        var useArtX = mode === 'Creative' || mode === 'Meow';
        xAction.href = useArtX ? xAction.dataset.xCreativeHref : xAction.dataset.xHref;
      }
      if (githubAction && githubIcon) {
        var useYoutube = mode === 'Creative' || mode === 'Meow';
        githubAction.href = useYoutube ? githubAction.dataset.youtubeHref : githubAction.dataset.githubHref;
        var ghLabel = useYoutube ? githubAction.dataset.youtubeLabel : githubAction.dataset.githubLabel;
        githubAction.title = ghLabel;
        githubAction.setAttribute('aria-label', ghLabel);
        githubIcon.className = useYoutube ? githubAction.dataset.youtubeIcon : githubAction.dataset.githubIcon;
      }
      if (modelPicker) {
        modelPicker.classList.toggle('is-creative-mode', mode === 'Creative');
        modelPicker.classList.toggle('is-meow-mode', mode === 'Meow');
      }
      if (aboutRoot) {
        aboutRoot.classList.toggle('is-creative-mode', mode === 'Creative');
        aboutRoot.classList.toggle('is-meow-mode', mode === 'Meow');
      }
      document.body.classList.toggle('is-about-creative-mode', mode === 'Creative');
      document.body.classList.toggle('is-about-meow-mode', mode === 'Meow');
      restartAutoCycleInterval();
    }

    setSpeechMode(currentSpeechMode);

    if (contactAction) {
      contactAction.addEventListener('click', function (event) {
        if (contactAction.dataset.contactMode !== 'wechat') return;
        var wechatModal = document.getElementById('WeChatMod');
        if (!wechatModal) return;
        event.preventDefault();
        wechatModal.classList.add('active');
      });
    }

    if (modelPicker) {
      var currentModel = modelPicker.querySelector('[data-about-model-current]');
      var modelOptions = Array.prototype.slice.call(modelPicker.querySelectorAll('[data-about-model-value]'));

      modelOptions.forEach(function (option) {
        option.addEventListener('click', function () {
          var selectedMode = option.getAttribute('data-about-model-value');
          if (currentModel) currentModel.textContent = selectedMode;
          setSpeechMode(selectedMode);
          modelOptions.forEach(function (otherOption) {
            otherOption.setAttribute('aria-selected', String(otherOption === option));
          });
          modelPicker.removeAttribute('open');
        });
      });

      document.addEventListener('click', function (event) {
        if (!modelPicker.contains(event.target)) modelPicker.removeAttribute('open');
      });

      modelPicker.addEventListener('keydown', function (event) {
        if (event.key === 'Escape') modelPicker.removeAttribute('open');
      });
    }

    function typePromptText() {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      var walker = document.createTreeWalker(promptBox, NodeFilter.SHOW_TEXT, {
        acceptNode: function (node) {
          var parent = node.parentElement;
          if (!parent || parent.closest('.about-prompt-actions')) return NodeFilter.FILTER_REJECT;
          if (!node.nodeValue.trim()) return NodeFilter.FILTER_REJECT;
          return NodeFilter.FILTER_ACCEPT;
        },
      });
      var textNodes = [];
      var node;
      while ((node = walker.nextNode())) {
        textNodes.push({
          node: node,
          text: node.nodeValue,
        });
      }
      if (!textNodes.length) return;

      promptBox.setAttribute('aria-busy', 'true');
      promptBox.classList.add('is-typing');
      textNodes.forEach(function (item) {
        item.node.nodeValue = '';
      });
      var caret = document.createElement('span');
      caret.className = 'about-prompt-caret';
      caret.setAttribute('aria-hidden', 'true');

      var nodeIndex = 0;
      var charIndex = 0;

      function moveCaretAfter(targetNode) {
        targetNode.parentNode.insertBefore(caret, targetNode.nextSibling);
      }

      function typeNextCharacter() {
        var item = textNodes[nodeIndex];
        moveCaretAfter(item.node);
        item.node.nodeValue += item.text.charAt(charIndex);
        charIndex += 1;

        if (charIndex >= item.text.length) {
          nodeIndex += 1;
          charIndex = 0;
        }

        if (nodeIndex < textNodes.length) {
          window.setTimeout(typeNextCharacter, typingSpeedMs);
          return;
        }

        promptBox.classList.remove('is-typing');
        promptBox.removeAttribute('aria-busy');
        caret.remove();
      }

      window.setTimeout(typeNextCharacter, 90);
    }

    typePromptText();

    if (aboutRoot && panelTriggers.length && inlinePanels.length) {
      function panelForTrigger(trigger) {
        return document.querySelector('[data-about-panel="' + trigger.getAttribute('data-about-panel-trigger') + '"]');
      }

      function closeInlinePanel(panel, trigger) {
        if (!panel || !trigger) return;
        panel.classList.remove('is-visible');
        trigger.setAttribute('aria-expanded', 'false');
        trigger.classList.remove('is-active');
        window.setTimeout(function () {
          if (!panel.classList.contains('is-visible')) panel.hidden = true;
          if (aboutRoot && panel.getAttribute('data-about-panel') === 'blog') {
            aboutRoot.classList.remove('is-blog-panel-open');
          }
          if (aboutRoot && panel.getAttribute('data-about-panel') === 'research') {
            aboutRoot.classList.remove('is-research-panel-open');
          }
          if (aboutRoot && panel.getAttribute('data-about-panel') === 'gallery') {
            aboutRoot.classList.remove('is-gallery-panel-open');
          }
          if (aboutRoot && panel.getAttribute('data-about-panel') === 'misc') {
            aboutRoot.classList.remove('is-misc-panel-open');
          }
        }, 420);
      }

      function scheduleInlinePanelRestore() {
        window.clearTimeout(panelRestoreTimer);
        aboutRoot.classList.add('is-panel-restoring');
        // Panel-specific classes are removed after 420ms. Release the collapsed
        // header at the same point so the textbox and header return together;
        // keep the mascot invisible until the motion is done.
        panelRestoreTimer = window.setTimeout(function () {
          aboutRoot.classList.remove('is-inline-panel-open');
        }, 430);
        window.setTimeout(function () {
          aboutRoot.classList.remove('is-panel-restoring');
          aboutRoot.classList.add('is-mascot-reappearing');
          window.setTimeout(function () {
            aboutRoot.classList.remove('is-mascot-reappearing');
          }, 520);
        }, 940);
      }

      function openInlinePanel(panel, trigger) {
        window.clearTimeout(panelRestoreTimer);
        window.clearTimeout(panelHideTimer);
        aboutRoot.classList.remove('is-panel-restoring');
        aboutRoot.classList.remove('is-mascot-reappearing');
        dismissSpeechBubble();
        inlinePanels.forEach(function (otherPanel) {
          if (otherPanel === panel) return;
          var otherTrigger = document.querySelector('[data-about-panel-trigger="' + otherPanel.getAttribute('data-about-panel') + '"]');
          closeInlinePanel(otherPanel, otherTrigger);
        });

        panel.hidden = false;
        trigger.setAttribute('aria-expanded', 'true');
        trigger.classList.add('is-active');
        aboutRoot.classList.add('is-panel-hiding-mascot');
        panelHideTimer = window.setTimeout(function () {
          aboutRoot.classList.remove('is-panel-hiding-mascot');
          window.requestAnimationFrame(function () {
            aboutRoot.classList.add('is-inline-panel-open');
            aboutRoot.classList.toggle('is-blog-panel-open', panel.getAttribute('data-about-panel') === 'blog');
            aboutRoot.classList.toggle('is-research-panel-open', panel.getAttribute('data-about-panel') === 'research');
            aboutRoot.classList.toggle('is-gallery-panel-open', panel.getAttribute('data-about-panel') === 'gallery');
            aboutRoot.classList.toggle('is-misc-panel-open', panel.getAttribute('data-about-panel') === 'misc');
            panel.classList.add('is-visible');
            if (['blog', 'gallery', 'misc'].indexOf(panel.getAttribute('data-about-panel')) !== -1) {
              return;
            }
            panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          });
        }, 260);
      }

      function closeAllInlinePanels() {
        window.clearTimeout(panelHideTimer);
        aboutRoot.classList.remove('is-panel-hiding-mascot');
        dismissSpeechBubble();
        inlinePanels.forEach(function (panel) {
          var trigger = document.querySelector('[data-about-panel-trigger="' + panel.getAttribute('data-about-panel') + '"]');
          closeInlinePanel(panel, trigger);
        });
        scheduleInlinePanelRestore();
      }

      collapseInlinePanels = closeAllInlinePanels;

      panelTriggers.forEach(function (trigger) {
        trigger.addEventListener('click', function (e) {
          var panel = panelForTrigger(trigger);
          if (!panel) return;
          e.preventDefault();
          if (panel.classList.contains('is-visible')) {
            closeAllInlinePanels();
            return;
          }
          openInlinePanel(panel, trigger);
        });
      });
    }

    window.addEventListener('keydown', function (e) {
      if (e.key !== 'Escape' || !aboutRoot || !aboutRoot.classList.contains('is-inline-panel-open')) return;
      closeAllInlinePanels();
    });

    function fitSpeechBubble() {
      bubble.style.setProperty('--speech-font-scale', '1');
      bubble.style.setProperty('--speech-bubble-width', 'fit-content');

      if (bubble.classList.contains('is-card-bubble')) {
        bubble.style.setProperty('--speech-bubble-width', 'max-content');
        var viewportSafeWidth = Math.max(window.innerWidth - 24, 240);
        var newsMaxWidth = Math.min(promptBox.getBoundingClientRect().width || 680, 760, viewportSafeWidth);
        bubble.style.setProperty('--speech-bubble-max-width', newsMaxWidth + 'px');
        return;
      }

      var promptWidth = promptBox.getBoundingClientRect().width;
      var bubbleStyle = window.getComputedStyle(bubble);
      var rotatorStyle = window.getComputedStyle(rotator);
      var horizontalChrome =
        parseFloat(bubbleStyle.paddingLeft) +
        parseFloat(bubbleStyle.paddingRight) +
        parseFloat(bubbleStyle.borderLeftWidth) +
        parseFloat(bubbleStyle.borderRightWidth);
      var measure = document.createElement('span');
      measure.textContent = rotator.textContent;
      measure.style.position = 'absolute';
      measure.style.visibility = 'hidden';
      measure.style.whiteSpace = 'nowrap';
      measure.style.fontFamily = rotatorStyle.fontFamily;
      measure.style.fontSize = bubbleStyle.fontSize;
      measure.style.fontWeight = rotatorStyle.fontWeight;
      measure.style.letterSpacing = rotatorStyle.letterSpacing;
      document.body.appendChild(measure);
      var textWidth = measure.getBoundingClientRect().width;
      measure.remove();
      var naturalWidth = textWidth + horizontalChrome;
      if (!promptWidth || !textWidth) return;

      if (naturalWidth > promptWidth) {
        bubble.classList.add('is-card-bubble');
        bubble.style.setProperty('--speech-bubble-width', 'max-content');
        var fallbackSafeWidth = Math.max(window.innerWidth - 24, 240);
        var fallbackMaxWidth = Math.min(promptWidth, 760, fallbackSafeWidth);
        bubble.style.setProperty('--speech-bubble-max-width', fallbackMaxWidth + 'px');
        bubble.style.setProperty('--speech-font-scale', '1');
        return;
      }

      var fittedWidth = Math.min(naturalWidth, promptWidth);
      bubble.style.setProperty('--speech-bubble-width', fittedWidth + 'px');
      bubble.style.setProperty('--speech-font-scale', '1');
    }

    function updateSpeechPointer(done) {
      window.requestAnimationFrame(function () {
        fitSpeechBubble();

        window.requestAnimationFrame(function () {
          var identityRect = identity.getBoundingClientRect();
          var avatarRect = avatar.getBoundingClientRect();
          var bubbleRect = bubble.getBoundingClientRect();
          var promptRect = promptBox.getBoundingClientRect();
          var bubbleStyle = window.getComputedStyle(bubble);
          var tailSizeRaw = bubbleStyle.getPropertyValue('--speech-tail-size').trim();
          var rootFontSize = parseFloat(window.getComputedStyle(document.documentElement).fontSize) || 16;
          var tailSize = tailSizeRaw.endsWith('rem') ? parseFloat(tailSizeRaw) * rootFontSize : parseFloat(tailSizeRaw);
          var tailHalfDiagonal = ((tailSize || 0) * Math.SQRT2) / 2;
          var naturalTargetX = avatarRect.left + avatarRect.width / 2;
          var minBubbleCenter = promptRect.left + bubbleRect.width / 2;
          var maxBubbleCenter = promptRect.right - bubbleRect.width / 2;
          var targetX = Math.min(Math.max(naturalTargetX, minBubbleCenter), maxBubbleCenter) - identityRect.left;
          var targetTop = avatarRect.top - pointerOffset - tailHalfDiagonal - bubbleRect.height;

          if (bubble.classList.contains('is-card-bubble')) {
            var navbar = document.getElementById('navbar');
            var navbarBottom = navbar ? navbar.getBoundingClientRect().bottom : 0;
            targetTop = Math.max(targetTop, navbarBottom + 8);
          }

          bubble.style.setProperty('--speech-bubble-left', targetX + 'px');
          bubble.style.setProperty('--speech-bubble-top', targetTop - identityRect.top + 'px');
          if (done) done();
        });
      });
    }

    function showSpeechAfterMascotMove(revealClass, shouldShow) {
      window.clearTimeout(speechTimer);
      var requestId = ++speechRequestId;
      identity.classList.add('is-preparing-speech');
      identity.classList.remove('is-speaking');

      var done = false;
      function showSpeech() {
        if (done) return;
        done = true;
        avatar.removeEventListener('transitionend', onTransitionEnd);
        if (requestId !== speechRequestId || isMascotSpeechPaused() || !shouldShow()) {
          identity.classList.remove('is-preparing-speech');
          return;
        }
        updateSpeechPointer(function () {
          identity.classList.remove('is-preparing-speech');
          window.requestAnimationFrame(function () {
            if (!isMascotSpeechPaused() && shouldShow()) identity.classList.add('is-speaking');
          });
        });
      }

      function onTransitionEnd(e) {
        if (e.target === avatar && e.propertyName === 'transform') showSpeech();
      }

      avatar.addEventListener('transitionend', onTransitionEnd);
      speechTimer = window.setTimeout(showSpeech, mascotRevealFallbackMs);

      window.requestAnimationFrame(function () {
        identity.classList.add(revealClass);
      });
    }

    function dismissSpeechBubble() {
      speechRequestId += 1;
      window.clearTimeout(clickTimer);
      window.clearTimeout(speechTimer);
      window.clearTimeout(autoCycleStepTimer);
      clickPopActive = false;
      autoCycleActive = false;
      bubbleHoverActive = false;
      identity.classList.remove('is-hovered');
      identity.classList.remove('is-click-pop');
      identity.classList.remove('is-preparing-speech');
      identity.classList.remove('is-speaking');
    }

    function decorateSpeechMessage(message) {
      if (currentSpeechMode !== 'Academic' || message.indexOf('about-news-date') === -1) return message;
      return (
        message +
        ' <a class="about-news-archive" href="' +
        newsArchiveUrl +
        '" aria-label="Open full news archive">All News</a>'
      );
    }

    function renderSpeechMessage(message) {
      var isNewsBubble = currentSpeechMode === 'Academic' && message.indexOf('about-news-date') !== -1;
      bubble.classList.add('is-card-bubble');
      bubble.classList.toggle('is-news-bubble', isNewsBubble);
      rotator.innerHTML = decorateSpeechMessage(message);
    }

    function setGreeting(nextIndex) {
      identity.classList.add('is-preparing-speech');
      identity.classList.remove('is-speaking');
      index = nextIndex % names.length;
      renderSpeechMessage(names[index]);
      rotator.classList.remove('is-changing');
    }

    function setInteractionGreeting() {
      identity.classList.add('is-preparing-speech');
      identity.classList.remove('is-speaking');
      renderSpeechMessage(interactionMessages[interactionIndex]);
      rotator.classList.remove('is-changing');
      interactionIndex = (interactionIndex + 1) % interactionMessages.length;
    }

    function stopAutoSpeechCycle() {
      window.clearTimeout(autoCycleStepTimer);
      autoCycleActive = false;
      identity.classList.remove('is-click-pop');
      identity.classList.remove('is-preparing-speech');
      identity.classList.remove('is-speaking');
    }

    function scheduleAutoSpeechStop() {
      window.clearTimeout(autoCycleStepTimer);
      if (!bubbleHoverActive) autoCycleStepTimer = window.setTimeout(stopAutoSpeechCycle, autoSpeechDurationMs);
    }

    function stopClickSpeech() {
      window.clearTimeout(speechTimer);
      identity.classList.remove('is-click-pop');
      identity.classList.remove('is-preparing-speech');
      identity.classList.remove('is-speaking');
      clickPopActive = false;
    }

    function scheduleClickSpeechStop() {
      window.clearTimeout(clickTimer);
      if (!bubbleHoverActive) clickTimer = window.setTimeout(stopClickSpeech, autoSpeechDurationMs);
    }

    function extendAutoSpeechCycle() {
      if (!autoCycleActive) return false;
      if (isMascotSpeechPaused()) {
        stopAutoSpeechCycle();
        return false;
      }
      scheduleAutoSpeechStop();
      return true;
    }

    function startAutoSpeechCycle() {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      if (isMascotSpeechPaused()) return;
      if (clickPopActive || autoCycleActive || identity.classList.contains('is-hovered')) return;

      autoCycleActive = true;
      setGreeting(autoCycleIndex);
      autoCycleIndex = (autoCycleIndex + 1) % names.length;
      showSpeechAfterMascotMove('is-click-pop', function () {
        return autoCycleActive && identity.classList.contains('is-click-pop') && !clickPopActive;
      });

      scheduleAutoSpeechStop();
    }

    avatar.addEventListener('mouseenter', function () {
      if (isMascotSpeechPaused()) return;
      if (extendAutoSpeechCycle()) return;
      if (!clickPopActive) {
        setInteractionGreeting();
        showSpeechAfterMascotMove('is-hovered', function () {
          return identity.classList.contains('is-hovered') && !clickPopActive;
        });
      }
    });

    bubble.addEventListener('mouseenter', function () {
      bubbleHoverActive = true;
      if (autoCycleActive) window.clearTimeout(autoCycleStepTimer);
      if (clickPopActive) window.clearTimeout(clickTimer);
    });

    bubble.addEventListener('mouseleave', function () {
      bubbleHoverActive = false;
      if (autoCycleActive) scheduleAutoSpeechStop();
      if (clickPopActive) scheduleClickSpeechStop();
    });

    identity.addEventListener('mouseleave', function () {
      window.clearTimeout(speechTimer);
      identity.classList.remove('is-hovered');
      if (!clickPopActive && !autoCycleActive) {
        identity.classList.remove('is-preparing-speech');
        identity.classList.remove('is-speaking');
      }
    });

    avatar.addEventListener('click', function () {
      if (isMascotSpeechPaused()) return;
      window.clearTimeout(clickTimer);
      if (autoCycleActive) stopAutoSpeechCycle();
      clickPopActive = true;
      setInteractionGreeting();
      identity.classList.remove('is-speaking');
      identity.classList.remove('is-hovered');
      showSpeechAfterMascotMove('is-click-pop', function () {
        return identity.classList.contains('is-click-pop');
      });

      scheduleClickSpeechStop();
    });

    window.addEventListener('resize', function () {
      if (identity.classList.contains('is-speaking')) {
        identity.classList.remove('is-speaking');
        updateSpeechPointer(function () {
          if (identity.classList.contains('is-hovered') || identity.classList.contains('is-click-pop')) {
            identity.classList.add('is-speaking');
          }
        });
      }
    });

    window.setTimeout(function () {
      startAutoSpeechCycle();
      autoCycleTimerId = window.setInterval(startAutoSpeechCycle, currentAutoCycleIntervalMs());
    }, autoCycleInitialDelayMs);
  })();
</script>
