---
layout: default
---
<div class="post about-jp">
  <header class="post-header">
    {% if page.profile.image %}
      {% assign title_avatar_path = page.profile.image | prepend: 'assets/img/' | relative_url %}
      {% assign title_icon_path = site.icon | prepend: 'assets/img/' | relative_url %}
    {% endif %}
    <div class="about-identity">
      {% if page.profile.image %}
        <button type="button" class="post-title-avatar-button" aria-label="Show greeting">
          <img class="post-title-avatar" src="{{ title_icon_path }}" alt="" aria-hidden="true">
        </button>
      {% endif %}
      <p class="about-hello">
        <span class="about-hello-rotator" aria-live="polite">Hi there / 你好 / こんにちは / 안녕 / Ciallo ～(∠・ω&lt; )⌒★</span>
      </p>
    </div>
    {% if page.subtitle %}
      <p class="desc">{{ page.subtitle }}</p>
    {% endif %}
  </header>

  {% if page.profile.image %}
    <div id="profile-avatar-modal" class="profile-avatar-modal" aria-hidden="true">
      <img src="{{ title_avatar_path }}" alt="Profile photo">
    </div>
  {% endif %}

  <article>
    {% if page.profile and page.profile.hide != true %}
      <div class="profile float-{% if page.profile.align == 'left' %}left{% else %}right{% endif %}">
        {% if page.profile.image %}
          {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
          {% if page.profile.image_circular %}
            {% assign profile_image_class = 'img-fluid z-depth-1 rounded-circle' %}
          {% else %}
            {% assign profile_image_class = 'img-fluid z-depth-1
      rounded' %}
          {% endif %}
          {% capture sizes %}(min-width: {{site.max_width}}) {{ site.max_width | minus: 30 | times: 0.3}}px, (min-width: 576px)
      30vw, 95vw"{% endcapture %}
          {%
            include figure.liquid loading="eager" fetchpriority="high" path=profile_image_path class=profile_image_class sizes=sizes alt=page.profile.image
            cache_bust=true
          %}
        {% endif %}
        {% if page.profile.more_info %}
          <div class="more-info">{{ page.profile.more_info }}</div>
        {% endif %}
      </div>
    {% endif %}

    {{ content }}

    <div style="clear: both;"></div>
  </article>
</div>
<script>
  (function () {
    var rotator = document.querySelector('.about-hello-rotator');
    var identity = document.querySelector('.about-identity');
    var avatar = document.querySelector('.post-title-avatar-button');
    var bubble = document.querySelector('.about-hello');
    var promptBox = document.querySelector('.about-prompt');
    var aboutRoot = document.querySelector('.about-jp');
    var panelTriggers = Array.prototype.slice.call(document.querySelectorAll('[data-about-panel-trigger]'));
    var inlinePanels = Array.prototype.slice.call(document.querySelectorAll('[data-about-panel]'));
    if (!rotator || !identity || !avatar || !bubble || !promptBox) return;

    var names = [
      '🤗 Hi there/你好/こんにちは/안녕/Ciallo ～(∠・ω< )⌒★',
      '🍭 This is Yolo Y. Tang (芸珑 in Mandarin or <ruby>夜<rt>よる</rt></ruby> in Japanese).',
      "🏠 Welcome to Yolo's personal website and have fun exploring!",
    ];
    var interactionMessages = [
      '🐾 Thanks for stopping by.',
      '🐈 Always happy to have curious visitors.',
      '✨ Feel free to explore the research and projects.',
      '📚 New ideas are usually hiding one click away.',
      '☕ Hope you enjoy the visit.',
    ];
    var index = 0;
    var interactionIndex = 0;
    var clickTimer = null;
    var speechTimer = null;
    var autoCycleStepTimer = null;
    var clickPopActive = false;
    var autoCycleActive = false;
    var autoCycleIndex = 0;
    var pointerOffset = 1;
    var mascotRevealFallbackMs = 360;
    var typingSpeedMs = 16;
    var autoCycleIntervalMs = 15000;
    var autoCycleInitialDelayMs = 10000;
    var autoSpeechDurationMs = 5000;

    function typePromptText() {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      var walker = document.createTreeWalker(promptBox, NodeFilter.SHOW_TEXT, {
        acceptNode: function (node) {
          var parent = node.parentElement;
          if (!parent || parent.closest('.about-prompt-actions')) return NodeFilter.FILTER_REJECT;
          if (!node.nodeValue.trim()) return NodeFilter.FILTER_REJECT;
          return NodeFilter.FILTER_ACCEPT;
        },
      });
      var textNodes = [];
      var node;
      while ((node = walker.nextNode())) {
        textNodes.push({
          node: node,
          text: node.nodeValue,
        });
      }
      if (!textNodes.length) return;

      promptBox.setAttribute('aria-busy', 'true');
      promptBox.classList.add('is-typing');
      textNodes.forEach(function (item) {
        item.node.nodeValue = '';
      });
      var caret = document.createElement('span');
      caret.className = 'about-prompt-caret';
      caret.setAttribute('aria-hidden', 'true');

      var nodeIndex = 0;
      var charIndex = 0;

      function moveCaretAfter(targetNode) {
        targetNode.parentNode.insertBefore(caret, targetNode.nextSibling);
      }

      function typeNextCharacter() {
        var item = textNodes[nodeIndex];
        moveCaretAfter(item.node);
        item.node.nodeValue += item.text.charAt(charIndex);
        charIndex += 1;

        if (charIndex >= item.text.length) {
          nodeIndex += 1;
          charIndex = 0;
        }

        if (nodeIndex < textNodes.length) {
          window.setTimeout(typeNextCharacter, typingSpeedMs);
          return;
        }

        promptBox.classList.remove('is-typing');
        promptBox.removeAttribute('aria-busy');
        caret.remove();
      }

      window.setTimeout(typeNextCharacter, 180);
    }

    typePromptText();

    if (aboutRoot && panelTriggers.length && inlinePanels.length) {
      function panelForTrigger(trigger) {
        return document.querySelector('[data-about-panel="' + trigger.getAttribute('data-about-panel-trigger') + '"]');
      }

      function closeInlinePanel(panel, trigger) {
        if (!panel || !trigger) return;
        panel.classList.remove('is-visible');
        trigger.setAttribute('aria-expanded', 'false');
        trigger.classList.remove('is-active');
        window.setTimeout(function () {
          if (!panel.classList.contains('is-visible')) panel.hidden = true;
        }, 420);
      }

      function openInlinePanel(panel, trigger) {
        inlinePanels.forEach(function (otherPanel) {
          if (otherPanel === panel) return;
          var otherTrigger = document.querySelector('[data-about-panel-trigger="' + otherPanel.getAttribute('data-about-panel') + '"]');
          closeInlinePanel(otherPanel, otherTrigger);
        });

        panel.hidden = false;
        trigger.setAttribute('aria-expanded', 'true');
        trigger.classList.add('is-active');
        window.requestAnimationFrame(function () {
          aboutRoot.classList.add('is-inline-panel-open');
          panel.classList.add('is-visible');
          panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        });
      }

      function closeAllInlinePanels() {
        inlinePanels.forEach(function (panel) {
          var trigger = document.querySelector('[data-about-panel-trigger="' + panel.getAttribute('data-about-panel') + '"]');
          closeInlinePanel(panel, trigger);
        });
        aboutRoot.classList.remove('is-inline-panel-open');
      }

      panelTriggers.forEach(function (trigger) {
        trigger.addEventListener('click', function (e) {
          var panel = panelForTrigger(trigger);
          if (!panel) return;
          e.preventDefault();
          if (panel.classList.contains('is-visible')) {
            closeAllInlinePanels();
            return;
          }
          openInlinePanel(panel, trigger);
        });
      });
    }

    window.addEventListener('keydown', function (e) {
      if (e.key !== 'Escape' || !aboutRoot || !aboutRoot.classList.contains('is-inline-panel-open')) return;
      inlinePanels.forEach(function (panel) {
        var trigger = document.querySelector('[data-about-panel-trigger="' + panel.getAttribute('data-about-panel') + '"]');
        if (panel.classList.contains('is-visible')) {
          panel.classList.remove('is-visible');
          if (trigger) {
            trigger.setAttribute('aria-expanded', 'false');
            trigger.classList.remove('is-active');
            trigger.focus();
          }
          window.setTimeout(function () {
            if (!panel.classList.contains('is-visible')) panel.hidden = true;
          }, 420);
          aboutRoot.classList.remove('is-inline-panel-open');
          return;
        }
      });
    });

    function fitSpeechBubble() {
      bubble.style.setProperty('--speech-font-scale', '1');
      bubble.style.setProperty('--speech-bubble-width', 'fit-content');

      var promptWidth = promptBox.getBoundingClientRect().width;
      var bubbleStyle = window.getComputedStyle(bubble);
      var rotatorStyle = window.getComputedStyle(rotator);
      var horizontalChrome =
        parseFloat(bubbleStyle.paddingLeft) +
        parseFloat(bubbleStyle.paddingRight) +
        parseFloat(bubbleStyle.borderLeftWidth) +
        parseFloat(bubbleStyle.borderRightWidth);
      var measure = document.createElement('span');
      measure.textContent = rotator.textContent;
      measure.style.position = 'absolute';
      measure.style.visibility = 'hidden';
      measure.style.whiteSpace = 'nowrap';
      measure.style.fontFamily = rotatorStyle.fontFamily;
      measure.style.fontSize = bubbleStyle.fontSize;
      measure.style.fontWeight = rotatorStyle.fontWeight;
      measure.style.letterSpacing = rotatorStyle.letterSpacing;
      document.body.appendChild(measure);
      var textWidth = measure.getBoundingClientRect().width;
      measure.remove();
      var naturalWidth = textWidth + horizontalChrome;
      if (!promptWidth || !textWidth) return;

      var availableTextWidth = Math.max(promptWidth - horizontalChrome - 12, 1);
      var scale = Math.min(1, availableTextWidth / textWidth);
      var fittedWidth = Math.min(naturalWidth, promptWidth);
      bubble.style.setProperty('--speech-bubble-width', fittedWidth + 'px');
      bubble.style.setProperty('--speech-font-scale', scale.toFixed(3));

      for (var i = 0; i < 4; i++) {
        var currentStyle = window.getComputedStyle(bubble);
        var currentAvailable =
          bubble.getBoundingClientRect().width -
          parseFloat(currentStyle.paddingLeft) -
          parseFloat(currentStyle.paddingRight) -
          parseFloat(currentStyle.borderLeftWidth) -
          parseFloat(currentStyle.borderRightWidth);
        var currentTextWidth = rotator.scrollWidth;

        if (currentTextWidth <= currentAvailable) break;

        scale = scale * (currentAvailable / currentTextWidth) * 0.985;
        bubble.style.setProperty('--speech-font-scale', scale.toFixed(3));
      }
    }

    function updateSpeechPointer(done) {
      window.requestAnimationFrame(function () {
        fitSpeechBubble();

        window.requestAnimationFrame(function () {
          var identityRect = identity.getBoundingClientRect();
          var avatarRect = avatar.getBoundingClientRect();
          var bubbleRect = bubble.getBoundingClientRect();
          var promptRect = promptBox.getBoundingClientRect();
          var bubbleStyle = window.getComputedStyle(bubble);
          var tailSizeRaw = bubbleStyle.getPropertyValue('--speech-tail-size').trim();
          var rootFontSize = parseFloat(window.getComputedStyle(document.documentElement).fontSize) || 16;
          var tailSize = tailSizeRaw.endsWith('rem') ? parseFloat(tailSizeRaw) * rootFontSize : parseFloat(tailSizeRaw);
          var tailHalfDiagonal = ((tailSize || 0) * Math.SQRT2) / 2;
          var naturalTargetX = avatarRect.left + avatarRect.width / 2;
          var minBubbleCenter = promptRect.left + bubbleRect.width / 2;
          var maxBubbleCenter = promptRect.right - bubbleRect.width / 2;
          var targetX = Math.min(Math.max(naturalTargetX, minBubbleCenter), maxBubbleCenter) - identityRect.left;
          var targetY = avatarRect.top - pointerOffset - identityRect.top;

          bubble.style.setProperty('--speech-bubble-left', targetX + 'px');
          bubble.style.setProperty('--speech-bubble-top', targetY - tailHalfDiagonal - bubbleRect.height + 'px');
          if (done) done();
        });
      });
    }

    function showSpeechAfterMascotMove(revealClass, shouldShow) {
      window.clearTimeout(speechTimer);
      identity.classList.remove('is-speaking');

      var done = false;
      function showSpeech() {
        if (done) return;
        done = true;
        avatar.removeEventListener('transitionend', onTransitionEnd);
        if (!shouldShow()) return;
        updateSpeechPointer(function () {
          if (shouldShow()) identity.classList.add('is-speaking');
        });
      }

      function onTransitionEnd(e) {
        if (e.target === avatar && e.propertyName === 'transform') showSpeech();
      }

      avatar.addEventListener('transitionend', onTransitionEnd);
      speechTimer = window.setTimeout(showSpeech, mascotRevealFallbackMs);

      window.requestAnimationFrame(function () {
        identity.classList.add(revealClass);
      });
    }

    function setGreeting(nextIndex) {
      index = nextIndex % names.length;
      rotator.innerHTML = names[index];
      rotator.classList.remove('is-changing');
    }

    function setInteractionGreeting() {
      rotator.innerHTML = interactionMessages[interactionIndex];
      rotator.classList.remove('is-changing');
      interactionIndex = (interactionIndex + 1) % interactionMessages.length;
    }

    function stopAutoSpeechCycle() {
      window.clearTimeout(autoCycleStepTimer);
      autoCycleActive = false;
      identity.classList.remove('is-click-pop');
      identity.classList.remove('is-speaking');
    }

    function extendAutoSpeechCycle() {
      if (!autoCycleActive) return false;
      window.clearTimeout(autoCycleStepTimer);
      autoCycleStepTimer = window.setTimeout(stopAutoSpeechCycle, autoSpeechDurationMs);
      return true;
    }

    function startAutoSpeechCycle() {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      if (clickPopActive || autoCycleActive || identity.classList.contains('is-hovered')) return;

      autoCycleActive = true;
      setGreeting(autoCycleIndex);
      autoCycleIndex = (autoCycleIndex + 1) % names.length;
      showSpeechAfterMascotMove('is-click-pop', function () {
        return autoCycleActive && identity.classList.contains('is-click-pop') && !clickPopActive;
      });

      autoCycleStepTimer = window.setTimeout(stopAutoSpeechCycle, autoSpeechDurationMs);
    }

    avatar.addEventListener('mouseenter', function () {
      if (extendAutoSpeechCycle()) return;
      if (!clickPopActive) {
        setInteractionGreeting();
        showSpeechAfterMascotMove('is-hovered', function () {
          return identity.classList.contains('is-hovered') && !clickPopActive;
        });
      }
    });

    bubble.addEventListener('mouseenter', extendAutoSpeechCycle);

    identity.addEventListener('mouseleave', function () {
      window.clearTimeout(speechTimer);
      identity.classList.remove('is-hovered');
      if (!clickPopActive && !autoCycleActive) identity.classList.remove('is-speaking');
    });

    avatar.addEventListener('click', function () {
      window.clearTimeout(clickTimer);
      if (autoCycleActive) stopAutoSpeechCycle();
      clickPopActive = true;
      setInteractionGreeting();
      identity.classList.remove('is-speaking');
      identity.classList.remove('is-hovered');
      showSpeechAfterMascotMove('is-click-pop', function () {
        return identity.classList.contains('is-click-pop');
      });

      clickTimer = window.setTimeout(function () {
        window.clearTimeout(speechTimer);
        identity.classList.remove('is-click-pop');
        identity.classList.remove('is-speaking');
        clickPopActive = false;
      }, 1800);
    });

    window.addEventListener('resize', function () {
      if (identity.classList.contains('is-speaking')) {
        identity.classList.remove('is-speaking');
        updateSpeechPointer(function () {
          if (identity.classList.contains('is-hovered') || identity.classList.contains('is-click-pop')) {
            identity.classList.add('is-speaking');
          }
        });
      }
    });

    window.setTimeout(function () {
      startAutoSpeechCycle();
      window.setInterval(startAutoSpeechCycle, autoCycleIntervalMs);
    }, autoCycleInitialDelayMs);
  })();
</script>
<script defer src="{{ '/assets/js/research.js' | relative_url | bust_file_cache }}"></script>
