<div id="selected-publications" class="publications">
  <div class="publication-cards">
    {% bibliography --group_by none --query @*[selected=true]* %}
  </div>
</div>
<script>
  (function () {
    var root = document.getElementById('selected-publications');
    var select = document.getElementById('pub-sort-by');
    if (!root || !select) return;

    select.value = 'cites';

    function parseShieldsStarsMessage(msg) {
      if (msg == null || msg === '') return 0;
      var lower = String(msg).trim().replace(/,/g, '').toLowerCase();
      if (lower.endsWith('k')) {
        var nk = parseFloat(lower.slice(0, -1));
        return isNaN(nk) ? 0 : Math.round(nk * 1000);
      }
      if (lower.endsWith('m')) {
        var nm = parseFloat(lower.slice(0, -1));
        return isNaN(nm) ? 0 : Math.round(nm * 1e6);
      }
      var n = parseInt(lower, 10);
      return isNaN(n) ? 0 : n;
    }

    function yearForRow(row) {
      if (!row) return 0;
      var y = parseInt(row.getAttribute('data-sort-year'), 10);
      return isNaN(y) ? 0 : y;
    }

    function citesForRow(row, citeMap) {
      if (!row || !citeMap) return 0;
      var id = row.getAttribute('data-scholar-id');
      if (!id || !Object.prototype.hasOwnProperty.call(citeMap, id)) return 0;
      return citeMap[id];
    }

    function starsForRow(row, starMap) {
      if (!row || !starMap) return 0;
      var repo = row.getAttribute('data-github-repo');
      if (!repo || !Object.prototype.hasOwnProperty.call(starMap, repo)) return 0;
      return starMap[repo];
    }

    function collectRepos() {
      var set = {};
      root.querySelectorAll('.publication-cards .row[data-github-repo]').forEach(function (row) {
        var repo = row.getAttribute('data-github-repo');
        if (repo) set[repo] = true;
      });
      return Object.keys(set);
    }

    function fetchStarMap(repos) {
      if (!repos.length) return Promise.resolve({});
      var starMap = {};
      return Promise.all(
        repos.map(function (repo) {
          var u = 'https://img.shields.io/github/stars/' + repo + '.json';
          return fetch(u, { cache: 'no-cache' })
            .then(function (r) {
              return r.json();
            })
            .then(function (j) {
              starMap[repo] = parseShieldsStarsMessage(j && j.message);
            })
            .catch(function () {
              starMap[repo] = 0;
            });
        })
      ).then(function () {
        return starMap;
      });
    }

    function sortList(criterion, citeMap, starMap) {
      root.querySelectorAll('.publication-cards').forEach(function (wrap) {
        var list = wrap.querySelector('ol.bibliography');
        if (!list) return;
        var items = Array.prototype.filter.call(list.children, function (el) {
          return el.tagName === 'LI';
        });
        items.sort(function (a, b) {
          var ra = a.querySelector('.row');
          var rb = b.querySelector('.row');
          var ca = citesForRow(ra, citeMap);
          var cb = citesForRow(rb, citeMap);
          var sa = starsForRow(ra, starMap);
          var sb = starsForRow(rb, starMap);
          var ya = yearForRow(ra);
          var yb = yearForRow(rb);
          var cmp;
          if (criterion === 'cites') {
            cmp = cb - ca;
            if (cmp !== 0) return cmp;
            cmp = sb - sa;
            if (cmp !== 0) return cmp;
            return yb - ya;
          }
          if (criterion === 'stars') {
            cmp = sb - sa;
            if (cmp !== 0) return cmp;
            cmp = cb - ca;
            if (cmp !== 0) return cmp;
            return yb - ya;
          }
          if (criterion === 'year') {
            cmp = yb - ya;
            if (cmp !== 0) return cmp;
            cmp = cb - ca;
            if (cmp !== 0) return cmp;
            return sb - sa;
          }
          cmp = cb - ca;
          if (cmp !== 0) return cmp;
          cmp = sb - sa;
          if (cmp !== 0) return cmp;
          return yb - ya;
        });
        items.forEach(function (li) {
          list.appendChild(li);
        });
      });
    }

    function applySort(citeMap, starMap) {
      var c = select.value;
      if (c !== 'year' && c !== 'cites' && c !== 'stars') c = 'cites';
      sortList(c, citeMap, starMap);
    }

    function wireSort(citeMap) {
      citeMap = citeMap || {};
      return fetchStarMap(collectRepos()).then(function (starMap) {
        applySort(citeMap, starMap);
        select.addEventListener('change', function () {
          applySort(citeMap, starMap);
        });
      });
    }

    if (window.__PUB_CITE_MAP__ !== undefined) {
      wireSort(window.__PUB_CITE_MAP__ || {});
    } else {
      window.addEventListener(
        'pubCiteMapReady',
        function (ev) {
          wireSort(ev.detail || {});
        },
        { once: true }
      );
    }
  })();
</script>
