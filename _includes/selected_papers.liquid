<div id="selected-publications" class="publications">
  <div class="publication-cards">
    {% selected_bibliography_sorted --group_by none --query @*[selected=true]* %}
  </div>
</div>
<script>
  (function () {
    var root = document.getElementById('selected-publications');
    var select = document.getElementById('pub-sort-by');
    if (!root || !select) return;

    var starMapCache = null;
    var starMapPromise = null;
    var initialOrder = new Map();

    root.querySelectorAll('.publication-cards ol.bibliography').forEach(function (list) {
      Array.prototype.forEach.call(list.children, function (el, idx) {
        if (el.tagName === 'LI') initialOrder.set(el, idx);
      });
    });

    /** Handles plain integers, commas, and compact k/m (YAML or shields-style). */
    function parseCount(val) {
      if (val == null || val === '') return 0;
      var s = String(val).trim().replace(/,/g, '');
      var lower = s.toLowerCase();
      if (lower.endsWith('k')) {
        var k = parseFloat(lower.slice(0, -1));
        return isNaN(k) ? 0 : Math.round(k * 1000);
      }
      if (lower.endsWith('m')) {
        var m = parseFloat(lower.slice(0, -1));
        return isNaN(m) ? 0 : Math.round(m * 1e6);
      }
      var n = parseInt(s, 10);
      return isNaN(n) ? 0 : n;
    }

    function citesForRow(row) {
      if (!row) return 0;
      return parseCount(row.getAttribute('data-sort-cites'));
    }

    function starsForRow(row) {
      if (!row) return 0;
      var repo = row.getAttribute('data-github-repo');
      if (repo && starMapCache && Object.prototype.hasOwnProperty.call(starMapCache, repo)) {
        return starMapCache[repo];
      }
      return parseCount(row.getAttribute('data-sort-stars'));
    }

    function yearForRow(row) {
      if (!row) return 0;
      var y = parseInt(row.getAttribute('data-sort-year'), 10);
      return isNaN(y) ? 0 : y;
    }

    function authorPosForRow(row) {
      if (!row) return 999;
      var p = parseInt(row.getAttribute('data-sort-author-pos'), 10);
      return isNaN(p) ? 999 : p;
    }

    function ensureStarMap() {
      if (starMapCache) return Promise.resolve(starMapCache);
      if (starMapPromise) return starMapPromise;
      var repos = [];
      root.querySelectorAll('.row[data-github-repo]').forEach(function (r) {
        var repo = r.getAttribute('data-github-repo');
        if (repo && repos.indexOf(repo) === -1) repos.push(repo);
      });
      if (!repos.length) {
        starMapCache = {};
        return Promise.resolve(starMapCache);
      }
      starMapPromise = Promise.all(
        repos.map(function (repo) {
          var u = 'https://img.shields.io/github/stars/' + repo + '.json';
          return fetch(u, { cache: 'default' })
            .then(function (r) {
              return r.json();
            })
            .then(function (j) {
              return { repo: repo, n: parseCount(j && j.message) };
            })
            .catch(function () {
              return { repo: repo, n: 0 };
            });
        })
      ).then(function (pairs) {
        starMapCache = {};
        pairs.forEach(function (p) {
          starMapCache[p.repo] = p.n;
        });
        return starMapCache;
      });
      return starMapPromise;
    }

    function sortList(criterion) {
      root.querySelectorAll('.publication-cards').forEach(function (wrap) {
        var list = wrap.querySelector('ol.bibliography');
        if (!list) return;
        var items = Array.prototype.filter.call(list.children, function (el) {
          return el.tagName === 'LI';
        });
        if (criterion === 'default') {
          items.sort(function (a, b) {
            return (initialOrder.get(a) || 0) - (initialOrder.get(b) || 0);
          });
          items.forEach(function (li) {
            list.appendChild(li);
          });
          return;
        }
        items.sort(function (a, b) {
          var ra = a.querySelector('.row');
          var rb = b.querySelector('.row');
          var ca = citesForRow(ra);
          var cb = citesForRow(rb);
          var sa = starsForRow(ra);
          var sb = starsForRow(rb);
          var ya = yearForRow(ra);
          var yb = yearForRow(rb);
          var pa = authorPosForRow(ra);
          var pb = authorPosForRow(rb);
          var cmp;
          if (criterion === 'cites') {
            cmp = cb - ca;
            if (cmp !== 0) return cmp;
            cmp = pa - pb;
            if (cmp !== 0) return cmp;
            cmp = sb - sa;
            if (cmp !== 0) return cmp;
            return yb - ya;
          }
          if (criterion === 'authorpos') {
            cmp = pa - pb;
            if (cmp !== 0) return cmp;
            cmp = cb - ca;
            if (cmp !== 0) return cmp;
            cmp = sb - sa;
            if (cmp !== 0) return cmp;
            return yb - ya;
          }
          if (criterion === 'stars') {
            cmp = sb - sa;
            if (cmp !== 0) return cmp;
            cmp = cb - ca;
            if (cmp !== 0) return cmp;
            return yb - ya;
          }
          if (criterion === 'year') {
            cmp = yb - ya;
            if (cmp !== 0) return cmp;
            cmp = cb - ca;
            if (cmp !== 0) return cmp;
            return sb - sa;
          }
          cmp = cb - ca;
          if (cmp !== 0) return cmp;
          cmp = sb - sa;
          if (cmp !== 0) return cmp;
          return yb - ya;
        });
        items.forEach(function (li) {
          list.appendChild(li);
        });
      });
    }

    select.addEventListener('change', function () {
      var c = select.value;
      if (c !== 'default' && c !== 'year' && c !== 'cites' && c !== 'authorpos' && c !== 'stars') c = 'default';
      if (c === 'stars') {
        ensureStarMap().then(function () {
          sortList('stars');
        });
      } else {
        sortList(c);
      }
    });

    ensureStarMap().catch(function () {});
  })();
</script>
