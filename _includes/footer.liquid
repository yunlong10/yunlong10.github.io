{% if site.footer_fixed %}
  <footer class="fixed-bottom" role="contentinfo">
    <div class="container mt-0">
      &copy; Copyright {{ site.time | date: '%Y' }} Yolo Tang. {{ site.footer_text }}
      {% if site.impressum_path %}
        <a href="{{ site.url }}{{ site.baseurl }}{{ site.impressum_path }}">Impressum</a>.
      {% endif %}
      {% if site.last_updated %}
        Last updated: {{ 'now' | date: '%B %d, %Y' }}.
      {% endif %}
    </div>
  </footer>
  <script>
    (function () {
      var footerHideTimeout;
      var footer = document.querySelector('footer.fixed-bottom');

      if (!footer) return;

      window.addEventListener(
        'scroll',
        function () {
          document.body.classList.add('footer-hidden-while-scrolling');
          window.clearTimeout(footerHideTimeout);
          footerHideTimeout = window.setTimeout(function () {
            document.body.classList.remove('footer-hidden-while-scrolling');
          }, 300);
        },
        { passive: true }
      );
    })();
  </script>
{% else %}
  <footer class="sticky-bottom mt-5" role="contentinfo">
    {% if site.newsletter.enabled %}
      {% include scripts/newsletter.liquid %}
    {% endif %}

    <div class="container">
      &copy; Copyright {{ site.time | date: '%Y' }} Yolo Tang. {{ site.footer_text }}
      {% if site.impressum_path %}
        <a href="{{ site.url }}{{ site.baseurl }}{{ site.impressum_path }}">Impressum</a>.
      {% endif %}
      {% if site.last_updated %}
        Last updated: {{ 'now' | date: '%B %d, %Y' }}.
      {% endif %}
    </div>
  </footer>
{% endif %}
