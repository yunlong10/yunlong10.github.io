{% assign ig_handle = 'Yolo' %}
{% assign ig_account = site.instagram_id | default: 'yoloytang.art' %}
{% assign ig_url = 'https://instagram.com/' | append: ig_account %}
{% assign ig_youtube = 'https://www.youtube.com/@yoloytang-art' %}
{% assign ig_x = 'https://x.com/yoloytang_art' %}
{% assign ig_discord = 'https://discord.com/users/1152784980167106662' %}
{% assign ig_avatar = '' %}
{% for file in site.static_files %}
  {% assign avatar_path = file.path | downcase %}
  {% if avatar_path contains '/assets/img/website/' %}
    {% if avatar_path contains '.jpg'
      or avatar_path contains '.jpeg'
      or avatar_path contains '.png'
      or avatar_path contains '.webp'
      or avatar_path contains '.gif'
    %}
      {% if ig_avatar == '' %}
        {% assign ig_avatar = file.path | relative_url %}
      {% endif %}
    {% endif %}
  {% endif %}
{% endfor %}

{% assign all_tags = '' | split: '' %}
{% for painting in site.data.paintings %}
  {% if painting.tags %}
    {% assign all_tags = all_tags | concat: painting.tags %}
  {% endif %}
{% endfor %}
{% assign all_tags = all_tags | uniq | sort %}

{% if all_tags.size > 0 %}
  <div class="ig-filters" role="tablist" aria-label="Filter by tag">
    <button type="button" class="ig-filter is-active" data-ig-filter="*" aria-selected="true">All</button>
    {% for tag in all_tags %}
      <button type="button" class="ig-filter" data-ig-filter="{{ tag | downcase }}" aria-selected="false">#{{ tag }}</button>
    {% endfor %}
  </div>
{% endif %}

<div class="ig-feed" aria-label="Painting gallery">
  {% assign by_date = site.data.paintings | sort: 'date' | reverse %}
  {% assign pinned_paintings = by_date | where: 'pin', true %}
  {% assign unpinned_paintings = by_date | where_exp: 'p', 'p.pin != true' %}
  {% assign sorted_paintings = pinned_paintings | concat: unpinned_paintings %}
  {% for painting in sorted_paintings %}
    {% if painting.images %}
      {% assign images = painting.images %}
    {% else %}
      {% assign images = painting.file | split: '~~~' %}
    {% endif %}
    {% assign image_label = painting.caption | markdownify | strip_html | strip | default: images.first %}
    {% assign painting_tags = painting.tags | join: '|' | downcase %}
    <article class="ig-post" data-tags="{{ painting_tags }}">
      <header class="ig-post-header">
        <button type="button" class="ig-avatar-button" aria-label="Show profile photo">
          <img class="ig-avatar" src="{{ ig_avatar }}" alt="{{ ig_handle }}" loading="lazy">
        </button>
        <div class="ig-post-meta">
          <span class="ig-username-row">
            <a class="ig-username" href="{{ ig_url }}" target="_blank" rel="noopener noreferrer">{{ ig_handle }}</a>
            <span class="ig-pronouns">she/her/hers</span>
          </span>
          {% if painting.location -%}
            <span class="ig-location">{{ painting.location }}</span>
          {%- endif %}
        </div>
        {% if painting.pin %}
          <span class="ig-pinned" title="Pinned" aria-label="Pinned">
            <svg viewBox="0 0 16 16" width="15" height="15" fill="currentColor">
              <path d="M4.146.146A.5.5 0 0 1 4.5 0h7a.5.5 0 0 1 .354.854L10.207 2.5l.646 2.583L13.5 7.5a.5.5 0 0 1-.354.854H8.5v5.5L8 15l-.5-.646V8.354H2.854A.5.5 0 0 1 2.5 7.5l2.647-2.417L5.793 2.5 4.146.854A.5.5 0 0 1 4.146.146z"/>
            </svg>
          </span>
        {% endif %}
        <a class="ig-more" href="{{ '/gallery/' | relative_url }}" aria-label="Open Gallery">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
            <circle cx="5" cy="12" r="1.6"/><circle cx="12" cy="12" r="1.6"/><circle cx="19" cy="12" r="1.6"/>
          </svg>
        </a>
      </header>

      <div class="ig-carousel{% if images.size > 1 %} is-multi{% endif %}">
        <div class="ig-carousel-track">
          {% for img in images %}
            {% assign yt_id = '' %}
            {% if img contains 'youtu.be/' %}
              {% assign yt_id = img | split: 'youtu.be/' | last | split: '?' | first | split: '&' | first %}
            {% elsif img contains 'youtube.com/watch?v=' %}
              {% assign yt_id = img | split: 'watch?v=' | last | split: '&' | first %}
            {% elsif img contains 'youtube.com/embed/' %}
              {% assign yt_id = img | split: '/embed/' | last | split: '?' | first | split: '&' | first %}
            {% endif %}
            {% if img contains '://' %}
              {% assign img_path = img %}
            {% else %}
              {% assign img_path = img | prepend: 'assets/img/painting/' | relative_url %}
            {% endif %}
            {% assign ext = img | split: '?' | first | split: '.' | last | downcase %}
            {% if yt_id != '' %}
              <div class="ig-slide ig-slide-embed">
                <div class="ig-embed ig-embed-yt" data-yt-id="{{ yt_id }}">
                  <img
                    class="ig-embed-thumb"
                    src="https://img.youtube.com/vi/{{ yt_id }}/hqdefault.jpg"
                    alt="{{ image_label | escape }}"
                    loading="lazy"
                  >
                  <button type="button" class="ig-embed-play" aria-label="Play video">
                    <svg viewBox="0 0 68 48" width="60" height="42">
                      <path class="ig-embed-play-bg" d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55c-2.93.78-4.64 3.26-5.42 6.19C.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="#f00"/><path d="M45 24 27 14v20" fill="#fff"/>
                    </svg>
                  </button>
                </div>
              </div>
            {% elsif ext == 'mp4' or ext == 'webm' or ext == 'mov' or ext == 'ogg' or ext == 'ogv' %}
              <div class="ig-slide ig-slide-video">
                <video class="ig-video" src="{{ img_path }}" controls playsinline preload="metadata" aria-label="{{ image_label | escape }}"></video>
              </div>
            {% else %}
              <a class="ig-slide ig-post-media" href="{{ img_path }}" data-ig-full="{{ img_path }}" aria-label="Open {{ image_label | escape }}">
                <img src="{{ img_path }}" alt="{{ image_label | escape }}" loading="lazy">
              </a>
            {% endif %}
          {% endfor %}
        </div>
        {% if images.size > 1 %}
          <button type="button" class="ig-carousel-nav ig-carousel-prev" aria-label="Previous">
            <svg
              viewBox="0 0 24 24"
              width="18"
              height="18"
              fill="none"
              stroke="currentColor"
              stroke-width="2.4"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <polyline points="15 18 9 12 15 6"/>
            </svg>
          </button>
          <button type="button" class="ig-carousel-nav ig-carousel-next" aria-label="Next">
            <svg
              viewBox="0 0 24 24"
              width="18"
              height="18"
              fill="none"
              stroke="currentColor"
              stroke-width="2.4"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </button>
          <div class="ig-carousel-dots" aria-hidden="true">
            {% for img in images %}
              <span class="ig-dot{% if forloop.first %} is-active{% endif %}"></span>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <div class="ig-actions">
        <div class="ig-actions-left">
          <a class="ig-icon" href="{{ ig_x }}" target="_blank" rel="noopener noreferrer" aria-label="X">
            <i class="fa-brands fa-x-twitter" aria-hidden="true"></i>
          </a>
          <a class="ig-icon" href="{{ ig_url }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <i class="fa-brands fa-instagram" aria-hidden="true"></i>
          </a>
          <a class="ig-icon" href="{{ ig_youtube }}" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
            <i class="fa-brands fa-square-youtube" aria-hidden="true"></i>
          </a>
        </div>
        <div class="ig-actions-right">
          <a class="ig-icon" href="{{ ig_discord }}" target="_blank" rel="noopener noreferrer" aria-label="Discord">
            <i class="fa-brands fa-discord" aria-hidden="true"></i>
          </a>
        </div>
      </div>

      {% if painting.likes %}
        <div class="ig-likes">{{ painting.likes }} likes</div>
      {% endif %}

      {% if painting.caption %}
        <div class="ig-caption">
          <a class="ig-username" href="{{ ig_url }}" target="_blank" rel="noopener noreferrer">{{ ig_handle }}</a>
          <span class="ig-caption-text">{{ painting.caption | markdownify | remove: '<p>' | remove: '</p>' | strip }}</span>
        </div>
      {% endif %}

      {% if painting.tags %}
        <div class="ig-tags">
          {% for tag in painting.tags %}
            <button type="button" class="ig-tag" data-ig-filter="{{ tag | downcase }}">#{{ tag }}</button>
          {% endfor %}
        </div>
      {% endif %}

      {% if painting.date %}
        <time class="ig-date" datetime="{{ painting.date | date: '%Y-%m-%d' }}">{{ painting.date | date: '%B %-d, %Y' }}</time>
      {% endif %}
    </article>
  {% endfor %}
</div>

<div class="ig-lightbox" id="ig-lightbox" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Image viewer">
  <button type="button" class="ig-lightbox-close" aria-label="Close">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/>
    </svg>
  </button>
  <button type="button" class="ig-lightbox-nav ig-lightbox-prev" aria-label="Previous">
    <svg
      viewBox="0 0 24 24"
      width="26"
      height="26"
      fill="none"
      stroke="currentColor"
      stroke-width="2.2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <polyline points="15 18 9 12 15 6"/>
    </svg>
  </button>
  <button type="button" class="ig-lightbox-nav ig-lightbox-next" aria-label="Next">
    <svg
      viewBox="0 0 24 24"
      width="26"
      height="26"
      fill="none"
      stroke="currentColor"
      stroke-width="2.2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <polyline points="9 18 15 12 9 6"/>
    </svg>
  </button>
  <img class="ig-lightbox-img" src="" alt="">
</div>

<script>
  (function () {
    function syncGalleryAvatar() {
      var stored = '';
      try {
        stored = window.sessionStorage.getItem('navbarAvatar') || '';
      } catch (e) {
        stored = '';
      }
      if (!stored) return;
      var avatars = document.querySelectorAll('.ig-avatar');
      for (var i = 0; i < avatars.length; i++) {
        avatars[i].src = stored;
      }
    }
    syncGalleryAvatar();
    window.addEventListener('pageshow', syncGalleryAvatar);

    var navbarAvatarButton = document.querySelector('.navbar-menu-avatar');
    var buttons = document.querySelectorAll('.ig-avatar-button');
    for (var i = 0; i < buttons.length; i++) {
      buttons[i].addEventListener('click', function () {
        if (navbarAvatarButton) {
          navbarAvatarButton.click();
          window.setTimeout(syncGalleryAvatar, 0);
        }
      });
    }

    var lightbox = document.getElementById('ig-lightbox');
    if (lightbox && lightbox.parentNode !== document.body) {
      document.body.appendChild(lightbox);
    }
    var lightboxImg = lightbox ? lightbox.querySelector('.ig-lightbox-img') : null;
    var lightboxClose = lightbox ? lightbox.querySelector('.ig-lightbox-close') : null;
    var lightboxPrev = lightbox ? lightbox.querySelector('.ig-lightbox-prev') : null;
    var lightboxNext = lightbox ? lightbox.querySelector('.ig-lightbox-next') : null;
    var lightboxItems = [];
    var lightboxIndex = 0;

    function renderLightbox() {
      if (!lightboxItems.length) return;
      var item = lightboxItems[lightboxIndex];
      lightboxImg.src = item.src;
      lightboxImg.alt = item.alt || '';
      var multi = lightboxItems.length > 1;
      if (lightboxPrev) lightboxPrev.style.display = multi ? '' : 'none';
      if (lightboxNext) lightboxNext.style.display = multi ? '' : 'none';
      if (lightboxPrev) lightboxPrev.style.visibility = lightboxIndex <= 0 ? 'hidden' : 'visible';
      if (lightboxNext) lightboxNext.style.visibility = lightboxIndex >= lightboxItems.length - 1 ? 'hidden' : 'visible';
    }

    function openLightbox(items, index) {
      if (!lightbox || !lightboxImg || !items.length) return;
      lightboxItems = items;
      lightboxIndex = index || 0;
      renderLightbox();
      lightbox.classList.add('active');
      lightbox.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      if (!lightbox || !lightboxImg) return;
      lightbox.classList.remove('active');
      lightbox.setAttribute('aria-hidden', 'true');
      lightboxImg.src = '';
      lightboxItems = [];
      document.body.style.overflow = '';
    }

    function stepLightbox(dir) {
      if (!lightboxItems.length) return;
      var next = lightboxIndex + dir;
      if (next < 0 || next >= lightboxItems.length) return;
      lightboxIndex = next;
      renderLightbox();
    }

    var media = document.querySelectorAll('.ig-post-media');
    for (var m = 0; m < media.length; m++) {
      media[m].addEventListener('click', function (e) {
        e.preventDefault();
        var scope = this.closest('.ig-carousel') || this;
        var slides = scope.querySelectorAll('.ig-post-media');
        var items = [];
        var startIndex = 0;
        for (var s = 0; s < slides.length; s++) {
          if (slides[s] === this) startIndex = s;
          var slideImg = slides[s].querySelector('img');
          items.push({
            src: slides[s].getAttribute('data-ig-full') || slides[s].getAttribute('href'),
            alt: slideImg ? slideImg.alt : '',
          });
        }
        openLightbox(items, startIndex);
      });
    }

    if (lightboxClose)
      lightboxClose.addEventListener('click', function (e) {
        e.stopPropagation();
        closeLightbox();
      });
    if (lightboxPrev)
      lightboxPrev.addEventListener('click', function (e) {
        e.stopPropagation();
        stepLightbox(-1);
      });
    if (lightboxNext)
      lightboxNext.addEventListener('click', function (e) {
        e.stopPropagation();
        stepLightbox(1);
      });
    if (lightboxImg)
      lightboxImg.addEventListener('click', function (e) {
        e.stopPropagation();
        if (lightboxItems.length <= 1) closeLightbox();
      });
    if (lightbox) {
      lightbox.addEventListener('click', function () {
        closeLightbox();
      });
    }
    window.addEventListener('keydown', function (e) {
      if (!lightbox || !lightbox.classList.contains('active')) return;
      if (e.key === 'Escape') closeLightbox();
      else if (e.key === 'ArrowLeft') stepLightbox(-1);
      else if (e.key === 'ArrowRight') stepLightbox(1);
    });

    if (lightbox) {
      var touchStartX = 0;
      var touchStartY = 0;
      lightbox.addEventListener(
        'touchstart',
        function (e) {
          touchStartX = e.changedTouches[0].clientX;
          touchStartY = e.changedTouches[0].clientY;
        },
        { passive: true }
      );
      lightbox.addEventListener(
        'touchend',
        function (e) {
          var dx = e.changedTouches[0].clientX - touchStartX;
          var dy = e.changedTouches[0].clientY - touchStartY;
          if (Math.abs(dx) > 40 && Math.abs(dx) > Math.abs(dy)) {
            stepLightbox(dx < 0 ? 1 : -1);
          }
        },
        { passive: true }
      );
    }

    var filterButtons = document.querySelectorAll('.ig-filter');
    var posts = document.querySelectorAll('.ig-post');

    function applyFilter(filter) {
      for (var b = 0; b < filterButtons.length; b++) {
        var isActive = filterButtons[b].getAttribute('data-ig-filter') === filter;
        filterButtons[b].classList.toggle('is-active', isActive);
        filterButtons[b].setAttribute('aria-selected', String(isActive));
      }
      for (var p = 0; p < posts.length; p++) {
        var tags = (posts[p].getAttribute('data-tags') || '').split('|');
        var show = filter === '*' || tags.indexOf(filter) !== -1;
        posts[p].style.display = show ? '' : 'none';
      }
      layoutMasonry();
    }

    for (var f = 0; f < filterButtons.length; f++) {
      filterButtons[f].addEventListener('click', function () {
        applyFilter(this.getAttribute('data-ig-filter'));
      });
    }

    var tagButtons = document.querySelectorAll('.ig-tag');
    for (var t = 0; t < tagButtons.length; t++) {
      tagButtons[t].addEventListener('click', function () {
        applyFilter(this.getAttribute('data-ig-filter'));
        var filters = document.querySelector('.ig-filters');
        if (filters) filters.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      });
    }

    var ytEmbeds = document.querySelectorAll('.ig-embed-yt');
    for (var y = 0; y < ytEmbeds.length; y++) {
      ytEmbeds[y].addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();
        if (this.querySelector('iframe')) return;
        var id = this.getAttribute('data-yt-id');
        var iframe = document.createElement('iframe');
        iframe.src = 'https://www.youtube-nocookie.com/embed/' + id + '?autoplay=1&rel=0';
        iframe.title = 'YouTube video';
        iframe.setAttribute('frameborder', '0');
        iframe.setAttribute('allow', 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share');
        iframe.setAttribute('allowfullscreen', '');
        this.appendChild(iframe);
        this.classList.add('is-playing');
      });
    }

    var carousels = document.querySelectorAll('.ig-carousel.is-multi');
    for (var c = 0; c < carousels.length; c++) {
      (function (carousel) {
        var track = carousel.querySelector('.ig-carousel-track');
        var dots = carousel.querySelectorAll('.ig-dot');
        var prev = carousel.querySelector('.ig-carousel-prev');
        var next = carousel.querySelector('.ig-carousel-next');
        if (!track) return;

        function currentIndex() {
          return Math.round(track.scrollLeft / track.clientWidth);
        }

        function update() {
          var idx = currentIndex();
          for (var d = 0; d < dots.length; d++) {
            dots[d].classList.toggle('is-active', d === idx);
          }
          if (prev) prev.style.visibility = idx <= 0 ? 'hidden' : 'visible';
          if (next) next.style.visibility = idx >= dots.length - 1 ? 'hidden' : 'visible';
        }

        function scrollToIndex(idx) {
          idx = Math.max(0, Math.min(dots.length - 1, idx));
          track.scrollTo({ left: idx * track.clientWidth, behavior: 'smooth' });
        }

        var scrollTimer;
        track.addEventListener('scroll', function () {
          window.clearTimeout(scrollTimer);
          scrollTimer = window.setTimeout(update, 60);
        });
        if (prev)
          prev.addEventListener('click', function () {
            scrollToIndex(currentIndex() - 1);
          });
        if (next)
          next.addEventListener('click', function () {
            scrollToIndex(currentIndex() + 1);
          });
        for (var d = 0; d < dots.length; d++) {
          (function (i) {
            dots[i].addEventListener('click', function () {
              scrollToIndex(i);
            });
          })(d);
        }
        update();
      })(carousels[c]);
    }

    var feed = document.querySelector('.ig-feed');
    var masonryGap = 24;
    var masonryTarget = 340;
    var masonryLastWidth = 0;

    function layoutMasonry() {
      if (!feed) return;
      var items = [];
      var all = feed.querySelectorAll('.ig-post');
      for (var i = 0; i < all.length; i++) {
        if (all[i].style.display !== 'none') items.push(all[i]);
      }
      var containerWidth = feed.clientWidth;
      if (!containerWidth) return;
      masonryLastWidth = containerWidth;
      var cols = Math.max(1, Math.floor((containerWidth + masonryGap) / (masonryTarget + masonryGap)));
      var colWidth = (containerWidth - (cols - 1) * masonryGap) / cols;
      var colHeights = [];
      for (var c = 0; c < cols; c++) colHeights.push(0);
      feed.classList.add('is-masonry');
      for (var i = 0; i < items.length; i++) {
        var item = items[i];
        item.style.width = colWidth + 'px';
        var min = 0;
        for (var c = 1; c < cols; c++) {
          if (colHeights[c] < colHeights[min]) min = c;
        }
        var x = min * (colWidth + masonryGap);
        var y = colHeights[min];
        item.style.transform = 'translate(' + x + 'px,' + y + 'px)';
        colHeights[min] += item.offsetHeight + masonryGap;
      }
      var maxH = 0;
      for (var c = 0; c < cols; c++) {
        if (colHeights[c] > maxH) maxH = colHeights[c];
      }
      feed.style.height = Math.max(0, maxH - masonryGap) + 'px';
    }

    if (feed) {
      layoutMasonry();
      var feedImages = feed.querySelectorAll('img');
      for (var fi = 0; fi < feedImages.length; fi++) {
        if (feedImages[fi].complete) continue;
        feedImages[fi].addEventListener('load', layoutMasonry);
        feedImages[fi].addEventListener('error', layoutMasonry);
      }
      window.addEventListener('load', layoutMasonry);
      var resizeTimer;
      window.addEventListener('resize', function () {
        window.clearTimeout(resizeTimer);
        resizeTimer = window.setTimeout(layoutMasonry, 120);
      });
      if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(layoutMasonry);
      }
      if (window.ResizeObserver) {
        var ro = new ResizeObserver(function () {
          if (feed.clientWidth && feed.clientWidth !== masonryLastWidth) layoutMasonry();
        });
        ro.observe(feed);
      }
    }
  })();
</script>
