<header>
  <!-- Nav Bar -->
  <nav id="navbar" class="navbar navbar-light navbar-expand-sm {% if site.navbar_fixed %}fixed-top{% else %}sticky-top{% endif %}" role="navigation">
    <div class="container">
      {% if page.permalink != '/' %}
        <a class="navbar-brand title font-weight-lighter" href="{{ site.baseurl }}/">
          <span class="font-weight-bold">Yolo</span>
          Tang
        </a>
      {% elsif site.enable_navbar_social %}
        <!-- Social Icons -->
        <div class="navbar-brand social">{% include social.liquid %}</div>
      {% endif %}
      <!-- Navbar Toggle -->
      <button
        class="navbar-toggler collapsed ml-auto"
        type="button"
        data-toggle="collapse"
        data-target="#navbarNav"
        aria-controls="navbarNav"
        aria-expanded="false"
        aria-label="Toggle navigation"
      >
        <span class="sr-only">Toggle navigation</span>
        <span class="icon-bar top-bar"></span>
        <span class="icon-bar middle-bar"></span>
        <span class="icon-bar bottom-bar"></span>
      </button>

      <div class="collapse navbar-collapse text-right" id="navbarNav">
        <ul class="navbar-nav ml-auto flex-nowrap">
          <!-- Other pages -->
          {% assign sorted_pages = site.pages | sort: 'nav_order' %}
          {% for p in sorted_pages %}
            {% if p.nav and p.autogen == null %}
              {% if p.dropdown %}
                {% assign has_active_child = false %}
                {% for child in p.children %}
                  {% if page.title == child.title %}
                    {% assign has_active_child = true %}
                  {% endif %}
                {% endfor %}
                <li class="nav-item dropdown {% if page.title == p.title or has_active_child %}active{% endif %}">
                  <a
                    class="nav-link dropdown-toggle"
                    href="#"
                    id="navbarDropdown"
                    role="button"
                    data-toggle="dropdown"
                    aria-haspopup="true"
                    aria-expanded="false"
                  >
                    {{- p.title }}
                    {% if page.title == p.title or has_active_child %}
                      <span class="sr-only">(current)</span>
                    {% endif %}
                  </a>
                  <div class="dropdown-menu dropdown-menu-right" aria-labelledby="navbarDropdown">
                    {% for child in p.children %}
                      {% if child.title == 'divider' %}
                        <div class="dropdown-divider"></div>
                      {% else %}
                        <a class="dropdown-item {% if page.title == child.title %}active{% endif %}" href="{{ child.permalink | relative_url }}">
                          {{- child.title -}}
                        </a>
                      {% endif %}
                    {% endfor %}
                  </div>
                </li>
              {% else %}
                {% assign parent_link = p.permalink | remove: 'index.html' %}
                {% assign is_active_page = false %}
                {% if parent_link == '/' %}
                  {% if page.url == '/' %}
                    {% assign is_active_page = true %}
                  {% endif %}
                {% elsif page.url contains parent_link %}
                  {% assign is_active_page = true %}
                {% endif %}
                <li class="nav-item {% if is_active_page %}active{% endif %}">
                  {% if p.permalink contains '/blog/' %}{% assign url = '/blog/' %} {% else %}{% assign url = p.url %}{% endif %}
                  <a class="nav-link" href="{{ url | relative_url }}">
                    {{- p.title }}
                    {% if is_active_page %}
                      <span class="sr-only">(current)</span>
                    {% endif %}
                  </a>
                </li>
              {% endif %}
            {% endif %}
          {% endfor %}
          {% if site.search_enabled %}
            <!-- Search -->
            <li class="nav-item">
              <button id="search-toggle" title="Search" onclick="openSearchModal()">
                <span class="nav-link">ctrl k <i class="ti ti-search"></i></span>
              </button>
            </li>
          {% endif %}
          <!-- Visitor Map -->
          <li class="nav-item">
            <button id="visitor-map-toggle" title="Visitor Map">
              <i class="fa-solid fa-earth-americas fa-spin" id="visitor-globe-icon"></i>
            </button>
          </li>
          {% if site.enable_darkmode %}
            <!-- Toggle theme mode -->
            <li class="toggle-container">
              <button id="light-toggle" title="Change theme">
                <i class="ti ti-moon-filled" id="light-toggle-dark"></i>
                <i class="ti ti-sun-filled" id="light-toggle-light"></i>
              </button>
            </li>
          {% endif %}
        </ul>
      </div>
    </div>
  </nav>
  {% if site.enable_progressbar %}
    <div id="page-load-progress" class="page-load-progress" aria-hidden="true">
      <div class="page-load-progress-ring">
        <div class="page-load-progress-ring-fill"></div>
        <span class="page-load-progress-label">0%</span>
      </div>
    </div>
    <script>
      (function () {
        var loader = document.getElementById('page-load-progress');
        try {
          if (sessionStorage.getItem('pageLoadProgressSeen') === '1') {
            if (loader) loader.classList.add('page-load-progress-done');
          } else {
            document.body.classList.add('page-is-loading');
          }
        } catch (e) {
          document.body.classList.add('page-is-loading');
        }
      })();
    </script>
    {% unless page.progressbar == false %}
      <!-- Scroll reading indicator: rainbow fill + site icon marker at the leading edge -->
      <div
        id="reading-progress"
        class="reading-progress"
        role="progressbar"
        aria-valuemin="0"
        aria-valuenow="0"
        aria-valuemax="100"
        aria-label="Reading progress"
        style="--reading-progress-pct: 0%;"
      >
        <div class="reading-progress-track" aria-hidden="true"></div>
        <div class="reading-progress-fill" aria-hidden="true"></div>
        <div class="reading-progress-marker" aria-hidden="true">
          <span class="reading-progress-marker-inner">
            {% if site.icon != blank and site.icon.size <= 4 %}
              <span class="reading-progress-marker-emoji">{{ site.icon }}</span>
            {% elsif site.icon != blank %}
              <img
                src="{{ site.icon | prepend: '/assets/img/' | relative_url | bust_file_cache }}"
                alt=""
                width="22"
                height="22"
                decoding="async"
                fetchpriority="low"
              >
            {% else %}
              <span class="reading-progress-marker-fallback"></span>
            {% endif %}
          </span>
        </div>
      </div>
    {% endunless %}
  {% endif %}
  <!-- Visitor Map Modal -->
  <div id="visitor-map-modal" class="visitor-map-modal">
    <div class="visitor-map-modal-backdrop"></div>
    <div class="visitor-map-modal-content">
      <div class="visitor-map-modal-header">
        <span>Visitor Map</span>
        <button class="visitor-map-close" aria-label="Close">&times;</button>
      </div>
      <div
        class="visitor-map"
        id="visitor-map-container"
        data-clustrmaps-src="https://clustrmaps.com/map_v2.js?cl=ffffff&d=mErswMtIf2K7G41Iql-K1paY9dnbAA1mf0bzUzgiHAs&co=5a9bd4&cmo=b83d7f&cmn=ff6ba3&w=300"
      ></div>
      <div class="visitor-map-footer">Thank you for your visit!</div>
    </div>
  </div>
  <script>
    (function () {
      var toggle = document.getElementById('visitor-map-toggle');
      var modal = document.getElementById('visitor-map-modal');
      var backdrop = modal.querySelector('.visitor-map-modal-backdrop');
      var closeBtn = modal.querySelector('.visitor-map-close');

      function openModal() {
        modal.classList.add('active');
        document.body.style.overflow = 'hidden';
        var container = document.getElementById('visitor-map-container');
        if (container && container.dataset.loaded !== '1') {
          container.dataset.loaded = '1';
          var s = document.createElement('script');
          s.async = true;
          s.id = 'clustrmaps';
          s.src = container.getAttribute('data-clustrmaps-src');
          container.appendChild(s);
        }
      }

      function closeModal() {
        modal.classList.remove('active');
        document.body.style.overflow = '';
      }

      toggle.addEventListener('click', function () {
        if (modal.classList.contains('active')) closeModal();
        else openModal();
      });
      backdrop.addEventListener('click', closeModal);
      closeBtn.addEventListener('click', closeModal);
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && modal.classList.contains('active')) closeModal();
      });
    })();
  </script>
</header>
