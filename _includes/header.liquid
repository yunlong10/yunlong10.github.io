<header>
  <!-- Nav Bar -->
  <nav id="navbar" class="navbar navbar-light navbar-expand-sm {% if site.navbar_fixed %}fixed-top{% else %}sticky-top{% endif %}" role="navigation">
    <div class="container">
      {% assign navbar_avatar_path = '' %}
      {% for file in site.static_files %}
        {% assign avatar_path = file.path | downcase %}
        {% if avatar_path contains '/assets/img/website/' %}
          {% if avatar_path contains '.jpg'
            or avatar_path contains '.jpeg'
            or avatar_path contains '.png'
            or avatar_path contains '.webp'
            or avatar_path contains '.gif'
          %}
            {% if navbar_avatar_path == '' %}
              {% assign navbar_avatar_path = file.path | relative_url %}
            {% endif %}
          {% endif %}
        {% endif %}
      {% endfor %}
      <button type="button" class="navbar-menu-avatar" aria-label="Show profile photo" aria-controls="navbar-avatar-modal">
        <img
          {% if navbar_avatar_path != '' %}
            src="{{ navbar_avatar_path }}"
          {% endif %}
          alt=""
          aria-hidden="true"
        >
      </button>
      <a class="navbar-brand title font-weight-lighter navbar-brand-centered" href="{{ site.baseurl }}/">
        <span class="font-weight-bold">Yolo</span>
        Tang
      </a>

      <div class="collapse navbar-collapse text-right" id="navbarNav">
        <ul class="navbar-nav ml-auto flex-nowrap">
          <!-- Other pages -->
          {% assign sorted_pages = site.pages | sort: 'nav_order' %}
          {% for p in sorted_pages %}
            {% if p.nav and p.autogen == null %}
              {% if p.dropdown %}
                {% assign has_active_child = false %}
                {% for child in p.children %}
                  {% if page.title == child.title %}
                    {% assign has_active_child = true %}
                  {% endif %}
                {% endfor %}
                <li class="nav-item dropdown {% if page.title == p.title or has_active_child %}active{% endif %}">
                  <a
                    class="nav-link dropdown-toggle"
                    href="#"
                    id="navbarDropdown"
                    role="button"
                    data-toggle="dropdown"
                    aria-haspopup="true"
                    aria-expanded="false"
                  >
                    {{- p.title }}
                    {% if page.title == p.title or has_active_child %}
                      <span class="sr-only">(current)</span>
                    {% endif %}
                  </a>
                  <div class="dropdown-menu dropdown-menu-right" aria-labelledby="navbarDropdown">
                    {% for child in p.children %}
                      {% if child.title == 'divider' %}
                        <div class="dropdown-divider"></div>
                      {% else %}
                        <a class="dropdown-item {% if page.title == child.title %}active{% endif %}" href="{{ child.permalink | relative_url }}">
                          {{- child.title -}}
                        </a>
                      {% endif %}
                    {% endfor %}
                  </div>
                </li>
              {% else %}
                {% assign parent_link = p.permalink | remove: 'index.html' %}
                {% assign is_active_page = false %}
                {% if parent_link == '/' %}
                  {% if page.url == '/' %}
                    {% assign is_active_page = true %}
                  {% endif %}
                {% elsif page.url contains parent_link %}
                  {% assign is_active_page = true %}
                {% endif %}
                <li class="nav-item {% if is_active_page %}active{% endif %}">
                  {% if p.permalink contains '/blog/' %}{% assign url = '/blog/' %} {% else %}{% assign url = p.url %}{% endif %}
                  <a class="nav-link" href="{{ url | relative_url }}">
                    {{- p.title }}
                    {% if is_active_page %}
                      <span class="sr-only">(current)</span>
                    {% endif %}
                  </a>
                </li>
              {% endif %}
            {% endif %}
          {% endfor %}
          {% if site.search_enabled %}
            <!-- Search -->
            <li class="nav-item">
              <button id="search-toggle" title="Search" onclick="openSearchModal()">
                <span class="nav-link">ctrl k <i class="ti ti-search"></i></span>
              </button>
            </li>
          {% endif %}
        </ul>
      </div>
      {% if site.enable_darkmode %}
        <!-- Toggle theme mode -->
        <div class="toggle-container navbar-theme-toggle">
          <button id="light-toggle" title="Change theme">
            <i class="ti ti-device-desktop" id="light-toggle-system"></i>
            <i class="ti ti-sun" id="light-toggle-light"></i>
            <i class="ti ti-moon" id="light-toggle-dark"></i>
          </button>
        </div>
      {% endif %}
    </div>
  </nav>
  <div id="navbar-avatar-modal" class="navbar-avatar-modal" aria-hidden="true">
    <img
      {% if navbar_avatar_path != '' %}
        src="{{ navbar_avatar_path }}"
      {% endif %}
      alt="Profile photo"
    >
  </div>
  <script>
    (function () {
      var avatarButton = document.querySelector('.navbar-menu-avatar');
      var avatarModal = document.getElementById('navbar-avatar-modal');
      if (!avatarButton || !avatarModal) return;
      var avatarImage = avatarButton.querySelector('img');
      var avatarModalImage = avatarModal.querySelector('img');
      var avatarImages = [];
      var currentAvatar = '';
      {% for file in site.static_files %}
        {% assign avatar_path = file.path | downcase %}
        {% if avatar_path contains '/assets/img/website/' %}
          {% if avatar_path contains '.jpg' or avatar_path contains '.jpeg' or avatar_path contains '.png' or avatar_path contains '.webp' or avatar_path contains '.gif' %}
            avatarImages.push('{{ file.path | relative_url }}');
          {% endif %}
        {% endif %}
      {% endfor %}

      function pickAvatar(excludedAvatar) {
        var selectedAvatar = avatarImages[Math.floor(Math.random() * avatarImages.length)];
        if (avatarImages.length > 1 && selectedAvatar === excludedAvatar) {
          selectedAvatar = avatarImages[(avatarImages.indexOf(selectedAvatar) + 1) % avatarImages.length];
        }
        return selectedAvatar;
      }

      function rememberAvatar(selectedAvatar) {
        try {
          window.sessionStorage.setItem('navbarAvatar', selectedAvatar);
        } catch (e) {
          // Private browsing or blocked storage should not affect avatar rendering.
        }
      }

      function setAvatar(selectedAvatar) {
        currentAvatar = selectedAvatar;
        avatarImage.src = selectedAvatar;
        rememberAvatar(selectedAvatar);
      }

      if (avatarImages.length && avatarImage && avatarModalImage) {
        var previousAvatar = '';
        try {
          previousAvatar = window.sessionStorage.getItem('navbarAvatar') || '';
        } catch (e) {
          previousAvatar = '';
        }
        setAvatar(pickAvatar(previousAvatar));
      }

      function closeAvatarModal() {
        avatarModal.classList.remove('active');
        avatarModal.setAttribute('aria-hidden', 'true');
      }

      avatarButton.addEventListener('click', function () {
        if (currentAvatar && avatarModalImage) avatarModalImage.src = currentAvatar;
        avatarModal.classList.add('active');
        avatarModal.setAttribute('aria-hidden', 'false');
        if (avatarImages.length && avatarImage) setAvatar(pickAvatar(currentAvatar));
      });

      avatarModal.addEventListener('click', function (e) {
        if (e.target === avatarModal) closeAvatarModal();
      });

      window.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeAvatarModal();
      });
    })();
  </script>
  {% if site.enable_progressbar %}
    {% unless page.progressbar == false %}
      <!-- Scroll reading indicator: rainbow fill -->
      <div
        id="reading-progress"
        class="reading-progress"
        role="progressbar"
        aria-valuemin="0"
        aria-valuenow="0"
        aria-valuemax="100"
        aria-label="Reading progress"
        style="--reading-progress-pct: 0%;"
      >
        <div class="reading-progress-track" aria-hidden="true"></div>
        <div class="reading-progress-fill" aria-hidden="true"></div>
      </div>
    {% endunless %}
  {% endif %}
</header>
